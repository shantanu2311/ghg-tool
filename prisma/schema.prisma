generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User & Auth ────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  name           String?   // encrypted
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String    // bcrypt hash
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  accounts       Account[]
  sessions       Session[]
  organisations  Organisation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Organisation ────────────────────────────────────────────────────────────

model Organisation {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  udyamNumber     String?  @unique
  sector          String   // NIC code or slug e.g. "iron_steel"
  subSector       String   // e.g. "eaf_mini_mill", "induction_furnace"
  state           String
  district        String?
  employeeCount   Int?
  turnoverBracket String?  // "micro" | "small" | "medium"
  contactEmail    String?
  contactPhone    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  facilities       Facility[]
  reportingPeriods ReportingPeriod[]
  customSources    CustomEmissionSource[]
}

// ── Facility ────────────────────────────────────────────────────────────────

model Facility {
  id             String   @id @default(cuid())
  orgId          String
  organisation   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name           String
  address        String?
  state          String
  district       String?
  gridRegion     String   // NORTHERN, SOUTHERN, WESTERN, EASTERN, NORTHEASTERN
  activityType   String   // facility type e.g. "eaf_mini_mill"
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  activityData   ActivityData[]
}

// ── Reporting Period ────────────────────────────────────────────────────────

model ReportingPeriod {
  id             String   @id @default(cuid())
  orgId          String
  organisation   Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  startDate      DateTime
  endDate        DateTime
  baseYearFlag   Boolean  @default(false)
  status         String   @default("draft") // draft | calculated | finalised
  createdAt      DateTime @default(now())
  activityData        ActivityData[]
  calculatedEmissions CalculatedEmission[]
  reports             Report[]
}

// ── Activity Data ───────────────────────────────────────────────────────────

model ActivityData {
  id               String   @id @default(cuid())
  facilityId       String
  facility         Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  periodId         String
  period           ReportingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  scope            Int      // 1, 2, 3
  sourceCategory   String   // e.g. "stationary_combustion", "grid_electricity", "purchased_goods"
  fuelType         String   // matches FuelProperty.code or free text for Scope 3
  description      String?
  inputMode        String   // "quantity" | "spend"
  quantity         Float?
  unit             String?
  spendInr         Float?   // spend in INR (for spend-based fallback)
  dataQualityFlag  String   @default("SECONDARY") // PRIMARY | SECONDARY | ESTIMATED
  month            Int?     // 1-12 for monthly; null = annual total
  encryptedData    String?  // AES-256-GCM encrypted JSON of sensitive values (quantity, spendInr)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  calculatedEmission CalculatedEmission?
}

// ── Emission Factor ─────────────────────────────────────────────────────────

model EmissionFactor {
  id             String    @id @default(cuid())
  fuelOrActivity String    // matches FuelProperty.code or activity key
  scope          Int       // 1, 2, 3
  scopeCategory  String    // e.g. "stationary_combustion", "process", "fugitive"
  co2Ef          Float     // kgCO2 per efUnit
  ch4Ef          Float?    // kgCH4 per efUnit
  n2oEf          Float?    // kgN2O per efUnit
  efUnit         String    // unit the EF expects (TJ, kWh, tonne, kg, km, tonne_km)
  region         String?   // null = national; NORTHERN/SOUTHERN etc for grid
  source         String    // IPCC, CEA, DEFRA, INDIA_GHG
  sourceVersion  String?   // e.g. "IPCC 2006 Vol 2 Table 2.2"
  sourceUrl      String?   // URL to source document
  validFrom      DateTime
  validTo        DateTime?
  active         Boolean   @default(true)
  notes          String?
  calculatedEmissions CalculatedEmission[]

  @@unique([fuelOrActivity, scope, scopeCategory, region])
}

// ── Calculated Emission ─────────────────────────────────────────────────────

model CalculatedEmission {
  id               String   @id @default(cuid())
  activityDataId   String   @unique
  activityData     ActivityData @relation(fields: [activityDataId], references: [id], onDelete: Cascade)
  efId             String
  emissionFactor   EmissionFactor @relation(fields: [efId], references: [id])
  periodId         String
  period           ReportingPeriod @relation(fields: [periodId], references: [id])
  co2Tonnes        Float
  ch4Co2eTonnes    Float
  n2oCo2eTonnes    Float
  totalCo2eTonnes  Float
  calculationMethod String  // description of method used
  calculationSteps String?  // JSON: full audit trail
  encryptedData    String?  // AES-256-GCM encrypted JSON of sensitive values (co2, ch4, n2o, total)
  calculatedAt     DateTime @default(now())
}

// ── Report ──────────────────────────────────────────────────────────────────

model Report {
  id                  String   @id @default(cuid())
  orgId               String
  periodId            String
  period              ReportingPeriod @relation(fields: [periodId], references: [id])
  scope1Total         Float
  scope2Total         Float
  scope3Total         Float
  scope3ByCategory    String?  // JSON
  energyConsumedGj    Float
  renewablePercent    Float?
  intensityPerTurnover Float?
  intensityPerProduct  Float?
  intensityPerEmployee Float?
  dataQualityScore    Float
  reportFormat        String   // BRSR | ISO | DETAILED | BENCHMARK
  encryptedData       String?  // AES-256-GCM encrypted JSON of sensitive values (scope totals, intensity)
  generatedAt         DateTime @default(now())
}

// ── Reference Tables ────────────────────────────────────────────────────────

model FuelProperty {
  id              String  @id @default(cuid())
  code            String  @unique // e.g. "DIESEL_HSD"
  name            String
  category        String  // fuel | refrigerant | material | electricity
  baseUnit        String
  density         Float?  // kg/L
  ncvTjPerGg      Float?  // Net Calorific Value in TJ/Gg
  co2EfKgPerTj    Float?  // kgCO2/TJ (from blueprint fuel table)
  defaultPriceInr Float?  // INR per common purchase unit
  alternateUnits  String? // JSON array of alternate units
  commonMsmeUse   String?
  source          String? // source document reference
  sourceUrl       String? // URL to source
  notes           String?
}

model GwpValue {
  id               String  @id @default(cuid())
  gas              String  // CO2, CH4, N2O, SF6, R22, etc.
  gwp              Float
  assessmentReport String  // AR5, AR6
  isDefault        Boolean @default(false)
  source           String? // e.g. "IPCC AR5 WG1 Table 8.A.1"
  sourceUrl        String?

  @@unique([gas, assessmentReport])
}

model UnitConversion {
  id        String  @id @default(cuid())
  fromUnit  String
  toUnit    String
  factor    Float
  fuelCode  String? // null = universal; else fuel-specific
  source    String? // source reference
  notes     String?

  @@unique([fromUnit, toUnit, fuelCode])
}

model SectorBenchmark {
  id            String @id @default(cuid())
  sector        String
  subSector     String
  metric        String // e.g. "tCO2e_per_tonne"
  bestPractice  Float
  sectorAverage Float
  worstQuartile Float
  source        String
  sourceUrl     String?
  year          Int

  @@unique([sector, subSector, metric])
}

// ── Module 2: Emission Reduction Technologies ──────────────────────────────

model ReductionTechnology {
  id                   String   @id @default(cuid())
  techId               String   @unique  // T001, T002, etc.
  name                 String           // "Variable Frequency Drives (VFDs)"
  category             String           // "Energy Efficiency - Cross Sector", "Sector Specific", etc.
  applicableSectors    String           // JSON array: ["iron_steel","textiles",...]
  scopeAddressed       String           // "Scope 1" | "Scope 2" | "Scope 1 + Scope 2"
  energyTypeSaved      String           // "Electrical" | "Thermal" | "Both"
  description          String           // Full description
  // ── Impact Metrics ──
  energySavingMinPct   Float            // e.g. 20
  energySavingMaxPct   Float            // e.g. 40
  co2ReductionMinPct   Float            // e.g. 20
  co2ReductionMaxPct   Float            // e.g. 40
  paybackMinYears      Float            // e.g. 0.5
  paybackMaxYears      Float            // e.g. 1.5
  capexMinLakhs        Float?           // e.g. 1
  capexMaxLakhs        Float?           // e.g. 15
  // ── Maturity & Evidence ──
  technologyReadiness  String           // "Commercially mature" | "Early commercial" | "Emerging"
  demonstratedInIndia  Boolean
  indianClusters       String?          // JSON array of cluster names
  // ── Matching Rules ──
  matchesFuelTypes     String?          // JSON array: ["COAL_INDIAN","COKE","FURNACE_OIL"]
  matchesCategories    String?          // JSON array: ["stationary_combustion"]
  matchesSubSectors    String?          // JSON array: ["eaf_mini_mill","induction_furnace"]
  minEmissionThreshold Float?           // Only recommend if source > X tCO2e/yr
  // ── Source Traceability ──
  source               String
  sourceUrl            String?
  // ── Relations ──
  fundingLinks         TechFundingLink[]
}

// ── Module 3: Funding Schemes ──────────────────────────────────────────────

model FundingScheme {
  id                  String   @id @default(cuid())
  schemeId            String   @unique  // S001, S002, etc.
  name                String           // "ADEETIE Scheme"
  implementingAgency  String           // "BEE, Ministry of Power"
  targetBeneficiary   String           // "Udyam-registered MSMEs"
  supportType         String           // "Interest subvention + Energy Audit + DPR"
  financialDetails    String           // Full description of financial support
  sectorsCovered      String           // JSON array or description
  // ── Eligibility ──
  eligibilityCriteria String           // Key requirements
  requiredDocuments   String?          // JSON array: ["Udyam certificate","DPR",...]
  minEnergySaving     Float?           // e.g. 10 (% minimum saving required)
  turnoverBrackets    String?          // JSON: ["micro","small","medium"]
  applicableStates    String?          // JSON array or null for pan-India
  // ── Status ──
  status              String           // "Active" | "Proposed" | "Concluded"
  validFrom           DateTime?
  validTo             DateTime?
  applicationUrl      String?          // Direct link to apply
  // ── Impact ──
  reportedImpact      String?          // Summary of results achieved
  // ── Source ──
  source              String
  sourceUrl           String?
  // ── Relations ──
  techLinks           TechFundingLink[]
  actionPlanSteps     ActionPlanStep[]
}

// ── Technology ↔ Funding Link (many-to-many) ───────────────────────────────

model TechFundingLink {
  id              String              @id @default(cuid())
  techId          String
  technology      ReductionTechnology @relation(fields: [techId], references: [id], onDelete: Cascade)
  fundingId       String
  funding         FundingScheme       @relation(fields: [fundingId], references: [id], onDelete: Cascade)
  subsidyPct      Float?              // e.g. 5 (interest subvention %)
  maxAmountLakhs  Float?              // cap on subsidy amount
  notes           String?             // special conditions

  @@unique([techId, fundingId])
}

// ── Financing Journey: Jargon Dictionary ──────────────────────────────────

model JargonEntry {
  id              String  @id @default(cuid())
  term            String  @unique          // "DEA", "DPR", "IGEA"
  fullForm        String                   // "Detailed Energy Audit"
  explanation     String                   // Plain English, 2-3 sentences
  whoDoesIt       String?                  // "BEE-certified Energy Auditor"
  typicalCostInr  String?                  // "₹50,000–₹2,00,000"
  isReimbursed    String?                  // "Yes, under ADEETIE up to ₹1L"
  relatedTerms    String?                  // JSON: ["CEA", "AEA", "IGEA"]
  source          String?
  sourceUrl       String?
}

// ── Financing Journey: Action Plan Steps ──────────────────────────────────

model ActionPlanStep {
  id              String        @id @default(cuid())
  schemeId        String
  scheme          FundingScheme @relation(fields: [schemeId], references: [id], onDelete: Cascade)
  stepNumber      Int
  title           String                   // "Submit Expression of Interest"
  description     String                   // Detailed how-to
  estimatedTime   String?                  // "30 minutes" | "2-4 weeks"
  estimatedCost   String?                  // "₹0" | "₹50,000–₹2,00,000 (reimbursable)"
  documentsNeeded String?                  // JSON: ["Udyam certificate", "12 months electricity bills"]
  actionUrl       String?                  // Direct link to form/portal
  actionLabel     String?                  // "Download EOI Format"
  tips            String?                  // Practical advice
  source          String?
  sourceUrl       String?

  @@unique([schemeId, stepNumber])
}

// ── Financing Journey: Service Providers ──────────────────────────────────

model ServiceProvider {
  id              String   @id @default(cuid())
  name            String                   // "National Productivity Council"
  type            String                   // "energy_auditor" | "esco" | "bank" | "sda" | "consultant"
  services        String?                  // JSON: ["DEA", "IGEA", "DPR"]
  states          String?                  // JSON: ["Maharashtra", "Gujarat"]
  sectors         String?                  // JSON: ["foundry", "forging"]
  accreditation   String?                  // "BEE AEA" | "ADEETIE Empaneled"
  contactEmail    String?
  contactPhone    String?
  website         String?
  address         String?
  source          String
  sourceUrl       String?
  active          Boolean  @default(true)
}

// ── Custom Emission Sources (user-defined) ────────────────────────────────

model CustomEmissionSource {
  id              String   @id @default(cuid())
  orgId           String
  organisation    Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name            String           // User's name: "Pet Coke", "Rice Husk Briquettes"
  code            String           // Auto-generated: "CUSTOM_<slug>"
  scope           Int              // 1, 2, or 3
  sourceCategory  String           // "stationary_combustion", "process", "custom"
  description     String?          // What this source is and how it's used
  // ── Emission Factor ──
  co2EfKgPerUnit  Float            // kgCO2 per baseUnit
  ch4EfKgPerUnit  Float?           // kgCH4 per baseUnit
  n2oEfKgPerUnit  Float?           // kgN2O per baseUnit
  efSource        String           // "IPCC 2006", "Energy auditor", "Supplier datasheet", "AI-estimated"
  efSourceUrl     String?
  // ── Unit Information ──
  baseUnit        String           // "tonne", "litre", "kg", "kWh", "m3"
  density         Float?           // kg/L if liquid
  ncvTjPerGg      Float?           // Net Calorific Value if fuel
  defaultPriceInr Float?           // INR per baseUnit (for spend-based fallback)
  // ── Metadata ──
  verified        Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  notes           String?

  @@unique([orgId, code])
}
